# Twilio Credentials — copy this file to .env and fill in your values
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_API_KEY_SID=SKxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_API_KEY_SECRET=your_api_key_secret_here

# Created when you run `node setup-twilio.js`
TWILIO_TWIML_APP_SID=

# Your Ada bot's Twilio phone number (add once allocated in Ada)
ADA_PHONE_NUMBER=+1xxxxxxxxxx

# Beeceptor endpoint URL (your mock customer context API)
BEECEPTOR_URL=https://app.beeceptor.com/api/your-endpoint-here

# Port for local server
PORT=3000
